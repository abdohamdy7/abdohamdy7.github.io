# Ignore generated site and cache directories
/_site/
/.sass-cache/
/.jekyll-cache/
/.jekyll-metadata

# Ignore the directory for local files during development
/local/

# Ignore the Gemfile that is generated
/Gemfile.lock

# Ignore files created by npm
/node_modules/
/package-lock.json

# Ignore the vendor file and bundle for alternative installation
/vendor/
/.bundle/

# Ignore local editor settings and caches
/.vscode/

# Ignore local Codex/agent scratch files
.codex
.agents/

# Ignore OS metadata
.DS_Store
Thumbs.db
